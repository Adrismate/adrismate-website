---
import "../styles/main.scss";

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Digital Product Designer — Strategy & Design" } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<link rel="icon" href="/icons/favicon.ico" />
		<title>{title} — Adrismate</title>
	</head>
	<body>
		<slot />
	</body>
</html>
