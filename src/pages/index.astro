---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/sections/Hero.astro";
import Nav from "../components/layout/Nav.astro";
import contactInfo from "../data/contactInfo";

const thumbnailModules = import.meta.glob<{ default: ImageMetadata }>("../content/projects/*/*.{png,jpg,jpeg,JPG,JPEG,PNG}", { eager: true });

const featuredProjects = (await getCollection("projects"))
	.sort((projectA, projectB) => {
		const featuredWeight = Number(projectB.data.featured) - Number(projectA.data.featured);
		if (featuredWeight !== 0) return featuredWeight;
		return projectB.data.date.getTime() - projectA.data.date.getTime();
	})
	.slice(0, 3)
	.map((project) => {
		const thumbnailPath = `../content/projects/${project.slug}/${project.data.thumbnail}`;
		const thumbnail = thumbnailModules[thumbnailPath]?.default;

		return {
			...project,
			thumbnail,
			excerpt: getProjectExcerpt(project.data.introduction),
			mainTag: project.data.tags[0] ?? "Case Study",
		};
	});

const faqs = [
	{
		question: "What is your design process?",
		answer: "I usually work in four blocks: alignment, exploration, design execution, and validation with real use-cases.",
	},
	{
		question: "How do you handle client feedback?",
		answer: "I centralize feedback in one place, prioritize by impact, and turn decisions into clear next actions so iterations stay focused.",
	},
	{
		question: "Can you provide examples of previous work?",
		answer: "Yes. The selected projects below are live case studies with context, process, and final outcomes.",
	},
	{
		question: "Can we make the project cheaper?",
		answer: "We can scope it to a smaller first phase, validate quickly, and expand only what proves value.",
	},
	{
		question: "What is your typical project timeline?",
		answer: "Most projects run between 3 and 8 weeks depending on complexity, stakeholders, and deliverables.",
	},
];

function getProjectExcerpt(introduction?: string): string {
	if (!introduction) return "Project overview coming soon.";

	const plainText = introduction.replace(/\*\*/g, "").replace(/\s+/g, " ").trim();
	if (plainText.length <= 140) return plainText;

	return `${plainText.slice(0, 137)}...`;
}
---

<BaseLayout title="Adrismate">
	<Nav />

	<main class="home" id="top">
		<Hero />

		<section class="home-bridge" id="services" aria-labelledby="bridge-title">
			<h2 class="home-bridge__headline" id="bridge-title">
				Strategy <span>meets</span> Design
			</h2>
		</section>

		<section class="home-projects" id="projects" aria-labelledby="projects-title">
			<div class="home-projects__inner">
				<h2 class="home-projects__title" id="projects-title">Selected Projects</h2>

				<div class="home-projects__content">
					<ul class="home-projects__index" aria-label="Selected project links">
						{
							featuredProjects.map((project) => (
								<li>
									<a href={`/projects/${project.slug}`}>{project.data.project_title}</a>
								</li>
							))
						}
					</ul>

					<div class="home-projects__cards">
						{
							featuredProjects.map((project) => (
								<article class="project-card">
									<a href={`/projects/${project.slug}`} class="project-card__link">
										<div class="project-card__media">
											{project.thumbnail ? (
												<Image src={project.thumbnail} alt={project.data.project_title} class="project-card__image" loading="lazy" />
											) : (
												<div class="project-card__placeholder" aria-hidden="true" />
											)}
										</div>

										<div class="project-card__body">
											<p class="project-card__tag">{project.mainTag}</p>
											<h3 class="project-card__title">{project.data.project_title}</h3>
											<p class="project-card__excerpt">{project.excerpt}</p>
										</div>
									</a>
								</article>
							))
						}
					</div>
				</div>
			</div>
		</section>

		<section class="home-faq" id="about" aria-labelledby="faq-title">
			<div class="home-faq__inner">
				<h2 class="home-faq__title" id="faq-title">FAQs</h2>

				<div class="home-faq__list">
					{
						faqs.map((faq) => (
							<details class="faq-item">
								<summary>{faq.question}</summary>
								<p>{faq.answer}</p>
							</details>
						))
					}
				</div>
			</div>
		</section>

		<section class="home-contact" aria-labelledby="contact-title">
			<div class="home-contact__inner">
				<div class="home-contact__intro">
					<h2 id="contact-title">Got a project in mind?</h2>
					<p>
						Get in touch with me: <a href={`mailto:${contactInfo.email}`}>send me an email</a>
					</p>
				</div>

				<ul class="home-contact__social" aria-label="Social links">
					<li>
						<a href={contactInfo.instagram} target="_blank" rel="noopener noreferrer">
							<span>Instagram</span>
							<span aria-hidden="true">-&gt;</span>
						</a>
					</li>
					<li>
						<a href={contactInfo.linkedin} target="_blank" rel="noopener noreferrer">
							<span>LinkedIn</span>
							<span aria-hidden="true">-&gt;</span>
						</a>
					</li>
					<li>
						<a href={contactInfo.dribble} target="_blank" rel="noopener noreferrer">
							<span>Dribbble</span>
							<span aria-hidden="true">-&gt;</span>
						</a>
					</li>
					<li>
						<a href={contactInfo.behance} target="_blank" rel="noopener noreferrer">
							<span>Behance</span>
							<span aria-hidden="true">-&gt;</span>
						</a>
					</li>
				</ul>

				<div class="home-contact__footer">
					<p class="home-contact__brand">Adrismate designs</p>
					<p class="home-contact__location">Based in Barcelona. To the world.</p>
					<p class="home-contact__copyright">© {new Date().getFullYear()} Adrismate Designs</p>
				</div>

				<a class="home-contact__to-top" href="#top" aria-label="Back to top">
					<span aria-hidden="true">^</span>
				</a>
			</div>
		</section>
	</main>
</BaseLayout>
